# ==================================================================
# Tartakk — Environment Variables
# ==================================================================

# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# CMI Payment Gateway (Morocco)
# Fill these ONLY when your CMI credentials have been issued.
# If empty or undefined, the app falls back to MOCK mode (simulated payments).
EXPO_PUBLIC_CMI_MERCHANT_ID=
EXPO_PUBLIC_CMI_STORE_KEY=
EXPO_PUBLIC_CMI_API_URL=https://payment.cmi.co.ma/fim/est3Dgate
EXPO_PUBLIC_CMI_RETURN_URL=https://yourdomain.com/payment/cmi-callback
EXPO_PUBLIC_CMI_FAILURE_URL=https://yourdomain.com/payment/cmi-failure
